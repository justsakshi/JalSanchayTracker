<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/bg_chip"
            android:backgroundTint="@null"
            android:tint="#A8CBEA"
            android:padding="8dp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="14dp"
            android:contentDescription="Back"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <TextView
                android:text="Report"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Your full rainfall history"
                android:textSize="12sp"
                android:textColor="#7EAECF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- All-time totals strip -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tank_card"
            android:padding="14dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:text="TOTAL SAVED"
                android:textSize="10sp"
                android:textColor="#7EAECF"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvTotalAllTime"
                android:text="— L"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tank_card"
            android:padding="14dp"
            android:layout_marginStart="8dp">

            <TextView
                android:text="IMPACT SCORE"
                android:textSize="10sp"
                android:textColor="#7EAECF"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvTotalDays"
                android:text="— days"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tabGraph"
            android:text="Graph"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_tab_active"/>

        <TextView
            android:id="@+id/tabMonthly"
            android:text="By Month"
            android:textSize="13sp"
            android:textColor="#7EAECF"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:background="@drawable/bg_tab_inactive"/>

        <TextView
            android:id="@+id/tabEntries"
            android:text="All Entries"
            android:textSize="13sp"
            android:textColor="#7EAECF"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_tab_inactive"/>
    </LinearLayout>

    <!-- Panel: Graph -->
    <LinearLayout
        android:id="@+id/panelGraph"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:visibility="visible">

        <TextView
            android:text="Monthly water saved (L)"
            android:textSize="12sp"
            android:textColor="#7EAECF"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.example.jalsanchaytracker.BarChartView
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Each bar represents total water saved in that calendar month."
            android:textSize="12sp"
            android:textColor="#4A7090"
            android:layout_marginTop="16dp"
            android:lineSpacingMultiplier="1.4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Panel: By Month -->
    <ScrollView
        android:id="@+id/panelMonthly"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/llMonthContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingBottom="40dp"/>
    </ScrollView>

    <!-- Panel: All Entries -->
    <ScrollView
        android:id="@+id/panelEntries"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/llEntriesContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingBottom="40dp"/>
    </ScrollView>

</LinearLayout>